<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cyber Cafe Management</title>
    <link rel="stylesheet" href="../public/stylesheets/styles.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-800">
    <main>
        <nav>
            <div class="nav flex justify-between">
                <img src="https://image1.jdomni.in/jdomni_email/logoomni1_2011101548.png" alt="" width="200px">
                <div class="navbar">
                    <ul class="flex justify-end gap-10 text-green-200 text-2xl mt-8 mr-10">
                        <a href="/"><li class="cursor-pointer">Home</li></a>
                        <a href="/about"><li class="cursor-pointer">About Us</li></a>
                        <a href="/contact"><li class="cursor-pointer">Contact</li></a>
                        <a href="/login" class="cursor-pointer hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-purple-600 focus:ring-opacity-50 ...">Admin LogIn</a>
                        <a href="/signup" class="cursor-pointer hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-purple-600 focus:ring-opacity-50 ...">Sign Up</a>
                    </ul>
                </div>
            </div>
        </nav>

        <div class="w-full bg-slate-500 h-screen border-2 border-gray-300 text-center flex justify-between align-center">
            <div class="text-8xl text-gray-600 mt-72 font-serif w-2/4">Welcome To <span class="text-blue-600">JdOmni</span>  CYBER CAFE</div>
            <div class="m-auto mt-36 border-2 p-10 w-1/4 border-yellow-400 rounded-lg">

                <form action="/admin/loggin" method="post" class="flex flex-col gap-7 align-center">
                    <label for="name" class="text-3xl text-zinc-800 tracking-tighter mt-5">Admin Name</label>
                    <input type="text" name="username" class="text-xl tracking-tighter ml-7 w-72 p-2 rounded-md" placeholder="Admin Name" required>
                    <label for="password" class="text-3xl text-zinc-800 tracking-tighter">Password</label>
                    <input type="password" name="password" class="text-xl tracking-tighter ml-7 w-72 p-2 rounded-md" placeholder="Password" required>
                    <input type="submit" value="Log In" class="bg-red-700 text-2xl ml-7 text-white rounded-lg p-1 align-center w-2/4 cursor-pointer">
                    <div class="text-white text-center">Don't have an account? <a href="/signup" class="text-zinc-900">Sign Up</a></div>
                </form>
                
            </div>
        </div>

    </main>

    <footer class="bg-gray-800 text-gray-300 py-10">
        <div class="container mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- About Section -->
            <div class="text-center md:text-left">
                <h3 class="text-lg font-semibold text-white mb-3">About Us</h3>
                <p class="text-sm">
                    Welcome to our website! We are committed to delivering high-quality services to our customers. Stay connected for updates and support.
                </p>
            </div>
    
            <!-- Links Section -->
            <div class="text-center">
                <h3 class="text-lg font-semibold text-white mb-3">Quick Links</h3>
                <ul class="text-sm space-y-2">
                    <li><a href="/" class="hover:text-blue-400">Home</a></li>
                    <li><a href="/about" class="hover:text-blue-400">About Us</a></li>
                    <li><a href="/contact" class="hover:text-blue-400">Contact Us</a></li>
                    <li><a href="/services" class="hover:text-blue-400">Services</a></li>
                </ul>
            </div>
    
            <!-- Contact Section -->
            <div class="text-center md:text-left">
                <h3 class="text-lg font-semibold text-white mb-3">Contact Us</h3>
                <ul class="text-sm">
                    <li>Email: <a href="mailto:support@example.com" class="hover:text-blue-400">support@example.com</a></li>
                    <li>Phone: <a href="tel:+123456789" class="hover:text-blue-400">+1 234 567 89</a></li>
                    <li>Address: 123, Main Street, City, Country</li>
                </ul>
            </div>
        </div>
    
        <div class="mt-8 border-t border-gray-700 pt-5 text-center text-sm">
            &copy; <%= new Date().getFullYear() %> Your Company Name. All rights reserved.
        </div>
    </footer>
    
    <script src="./public/javascripts/script.js"></script>
    <script src="./app.js"></script>
</body>
</html>
