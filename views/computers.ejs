<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Users and Computers</title>
    <link rel="stylesheet" href="../public/stylesheets/styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
    
    <div class="container mt-5">
        <a href="/dashboard"><button  class="bg-zinc-900 text-red-800">Back</button></a>
        <h1 class="mt-4 text-center text-blue-600">Computers</h1>
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Computer Name</th>
                    <th>Remove</th>
                </tr>
            </thead>
            <tbody>
                <% if (computers.length > 0) { %>
                    <% computers.forEach(computer => { %>
                        <tr>
                            <td><%= computer.ID %></td>
                            <td><%= computer.Name %></td>
                            <td>
                                <form action="/computers/delete/<%= computer.ID %>" method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-danger">Remove System</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="2" class="text-center">No computers found</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</body>
</html>
