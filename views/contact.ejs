<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
    <header class="bg-green-800 text-white py-6">
        <h1 class="text-center text-3xl font-bold">Contact Us</h1>
    </header>

    <main class="container mx-auto my-10 px-5">
        <section>
            <h2 class="text-2xl font-semibold text-green-800 mb-4">Get in Touch</h2>
            <form action="/contact" method="post" class="bg-white p-8 rounded-lg shadow-lg">
                <div class="mb-4">
                    <label for="name" class="block text-lg font-semibold text-gray-700">Your Name</label>
                    <input type="text" id="name" name="name" class="w-full border-gray-300 p-2 rounded-lg" required>
                </div>

                <div class="mb-4">
                    <label for="email" class="block text-lg font-semibold text-gray-700">Your Email</label>
                    <input type="email" id="email" name="email" class="w-full border-gray-300 p-2 rounded-lg" required>
                </div>

                <div class="mb-4">
                    <label for="message" class="block text-lg font-semibold text-gray-700">Your Message</label>
                    <textarea id="message" name="message" rows="5" class="w-full border-gray-300 p-2 rounded-lg" required></textarea>
                </div>

                <button type="submit" class="bg-green-700 text-white px-6 py-2 rounded-lg hover:bg-green-800">Send Message</button>
            </form>
        </section>

        <section class="mt-10">
            <h2 class="text-2xl font-semibold text-green-800 mb-4">Contact Information</h2>
            <p class="text-gray-700">
                Email: support@example.com<br>
                Phone: +1 234 567 89<br>
                Address: 123 Main Street, City, Country
            </p>
        </section>
    </main>

</body>

</html>
